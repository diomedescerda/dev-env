# i3status configuration file.
# see "man i3status" for documentation.

# It is important that this file is edited as UTF-8.
# The following line should contain a sharp s:
# ß
# If the above line is not correctly displayed, fix your editor first!

general {
    colors = true
    interval = 5
    output_format = "i3bar"
}

order += "wireless _first_"
order += "path_exists VPN"
order += "battery all"
order += "disk /"
order += "memory"
order += "volume master"
order += "tztime time"
order += "tztime date"

wireless _first_ {
    format_up = "「電 %quality」〜 %essid"
    format_down = "無線: 未接続"
}

path_exists VPN {
    path = "/proc/sys/net/ipv4/conf/nordlynx"
    format = "%title 存在"
    format_down = ""
}

battery all {
    format = "電池 %percentage"
}

disk "/" {
    format = "空 %avail"
}

memory {
    format = "メモ %used"
    threshold_degraded = "1G"
    format_degraded = "メモ ⚠️ 「%available」"
}

volume master {
    format = "音 %volume"
    format_muted = "ミュート"
}

tztime date {
    format = "%m月%d日（%a）"
}

tztime time {
    format = "時刻 %H:%M"
}
